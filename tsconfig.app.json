{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["node", "vite/client"],

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@poppy-ui/vue": ["./src/public.ts"],
      "@poppy-ui/vue/components/actions": ["./src/components/actions/public.ts"],
      "@poppy-ui/vue/components/display": ["./src/components/display/public.ts"],
      "@poppy-ui/vue/composables": ["./src/composables/public.ts"],
      "@poppy-ui/vue/types": ["./src/types/public.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/types/config.type.ts", "histoire.setup.ts"]
}
