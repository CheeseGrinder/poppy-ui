{
  "name": "poppy-vue",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/public.umd.js",
  "module": "./dist/public.es.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.es.js",
      "require": "./dist/public.umd.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.es.js",
      "require": "./dist/tailwind.umd.js"
    },
    "./components/*": {
      "types": "./dist/components/actions/*",
      "import": "./dist/components/actions/*",
      "require": "./dist/components/actions/*"
    },
    "./components/actions": {
      "types": "./dist/components/actions/public.d.ts",
      "import": "./dist/components/actions/public.es.js",
      "require": "./dist/components/actions/public.umd.js"
    },
    "./composables": {
      "types": "./dist/composables/public.d.ts",
      "import": "./dist/composables/public.es.js",
      "require": "./dist/composables/public.umd.js"
    },
    "./types": {
      "types": "./dist/types/public.d.ts",
      "import": "./dist/types/public.es.js",
      "require": "./dist/types/public.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "format": "biome format --fix",
    "format:check": "biome format",
    "lint": "biome lint --fix",
    "lint:check": "biome lint",
    "typecheck": "vue-tsc --build --force"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@histoire/plugin-vue": "^1.0.0-beta.1",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/tsconfig": "^0.9.1",
    "daisyui": "^5.5.20",
    "histoire": "^1.0.0-beta.1",
    "playwright": "^1.60.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.3.2"
  }
}
